generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                   String   @id @default(uuid())
  name                 String   @db.VarChar(255)
  slug                 String   @unique @db.VarChar(255)
  industry             String?  @db.VarChar(100)
  mfa_enforced         Boolean  @default(false)
  max_concurrent_calls Int      @default(100)
  timezone             String   @default("Europe/Stockholm") @db.VarChar(50)
  locale               String   @default("sv") @db.VarChar(10)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  deleted_at           DateTime?

  users       User[]
  invitations UserInvitation[]
  auditLogs   AuditLog[]
}

enum UserRole {
  admin
  manager
  agent
}

model User {
  id                 String    @id @default(uuid())
  org_id             String
  org                Organization @relation(fields: [org_id], references: [id])
  name               String    @db.VarChar(255)
  email              String    @unique @db.VarChar(255)
  password           String    @db.VarChar(255)
  role               UserRole
  email_verified_at  DateTime?
  mfa_enabled        Boolean   @default(false)
  mfa_secret         String?   @db.VarChar(255)
  mfa_recovery_codes Json?
  last_login_at      DateTime?
  last_login_ip      String?   @db.VarChar(45)
  is_active          Boolean   @default(true)
  invited_by         String?
  invitedBy          User?          @relation("UserInvites", fields: [invited_by], references: [id])
  invitedUsers       User[]         @relation("UserInvites")
  invited_at         DateTime?
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt
  deleted_at         DateTime?

  refreshTokens RefreshToken[]
  sessions      UserSession[]
  sentInvitations UserInvitation[]
  auditLogs     AuditLog[]
}

model RefreshToken {
  id         String    @id @default(uuid())
  token      String    @unique
  user_id    String
  user       User      @relation(fields: [user_id], references: [id])
  expires_at DateTime
  created_at DateTime  @default(now())
  revoked_at DateTime?
}

model UserSession {
  id             String   @id @default(uuid())
  user_id        String
  user           User     @relation(fields: [user_id], references: [id])
  ip_address     String   @db.VarChar(45)
  user_agent     String   @db.Text
  device_name    String?  @db.VarChar(255)
  last_active_at DateTime @default(now())
  expires_at     DateTime
  created_at     DateTime @default(now())
}

model UserInvitation {
  id          String   @id @default(uuid())
  org_id      String
  org         Organization @relation(fields: [org_id], references: [id])
  email       String   @db.VarChar(255)
  role        UserRole
  invited_by  String
  inviter     User     @relation(fields: [invited_by], references: [id])
  token       String   @unique @db.VarChar(64)
  accepted_at DateTime?
  expires_at  DateTime
  created_at  DateTime @default(now())
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  email      String   @db.VarChar(255)
  token      String   @unique @db.VarChar(64)
  expires_at DateTime
  created_at DateTime @default(now())
}

model AuditLog {
  id            String   @id @default(uuid())
  org_id        String
  org           Organization @relation(fields: [org_id], references: [id])
  user_id       String?
  user          User?    @relation(fields: [user_id], references: [id])
  action        String   @db.VarChar(100)
  resource_type String?  @db.VarChar(100)
  resource_id   String?
  metadata      Json?
  ip_address    String?  @db.VarChar(45)
  created_at    DateTime @default(now())
}
