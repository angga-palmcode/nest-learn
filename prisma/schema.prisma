generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                   String   @id @default(uuid())
  name                 String   @db.VarChar(255)
  slug                 String   @unique @db.VarChar(255)
  industry             String?  @db.VarChar(100)
  mfa_enforced         Boolean  @default(false)
  max_concurrent_calls Int      @default(100)
  timezone             String   @default("Europe/Stockholm") @db.VarChar(50)
  locale               String   @default("sv") @db.VarChar(10)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
  deleted_at           DateTime?

  users                User[]
  invitations          UserInvitation[]
  auditLogs            AuditLog[]
  consentRecords       ConsentRecord[]
  dncEntries           DncRegistry[]
  complianceChecks     ComplianceCheck[]
  recordingDisclosures RecordingDisclosure[]
}

enum UserRole {
  admin
  manager
  agent
}

model User {
  id                 String    @id @default(uuid())
  org_id             String
  org                Organization @relation(fields: [org_id], references: [id])
  name               String    @db.VarChar(255)
  email              String    @unique @db.VarChar(255)
  password           String    @db.VarChar(255)
  role               UserRole
  email_verified_at  DateTime?
  mfa_enabled        Boolean   @default(false)
  mfa_secret         String?   @db.VarChar(255)
  mfa_recovery_codes Json?
  last_login_at      DateTime?
  last_login_ip      String?   @db.VarChar(45)
  is_active          Boolean   @default(true)
  invited_by         String?
  invitedBy          User?          @relation("UserInvites", fields: [invited_by], references: [id])
  invitedUsers       User[]         @relation("UserInvites")
  invited_at         DateTime?
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt
  deleted_at         DateTime?

  failed_login_attempts Int       @default(0)
  locked_until          DateTime?

  refreshTokens   RefreshToken[]
  sessions        UserSession[]
  sentInvitations UserInvitation[]
  auditLogs       AuditLog[]
  mfaEmailTokens  MfaEmailToken[]
}

model RefreshToken {
  id         String    @id @default(uuid())
  token      String    @unique
  user_id    String
  user       User      @relation(fields: [user_id], references: [id])
  expires_at DateTime
  created_at DateTime  @default(now())
  revoked_at DateTime?
}

model UserSession {
  id             String   @id @default(uuid())
  user_id        String
  user           User     @relation(fields: [user_id], references: [id])
  ip_address     String   @db.VarChar(45)
  user_agent     String   @db.Text
  device_name    String?  @db.VarChar(255)
  last_active_at DateTime @default(now())
  expires_at     DateTime
  created_at     DateTime @default(now())
}

model UserInvitation {
  id          String   @id @default(uuid())
  org_id      String
  org         Organization @relation(fields: [org_id], references: [id])
  email       String   @db.VarChar(255)
  role        UserRole
  invited_by  String
  inviter     User     @relation(fields: [invited_by], references: [id])
  token       String   @unique @db.VarChar(64)
  accepted_at DateTime?
  expires_at  DateTime
  created_at  DateTime @default(now())
}

model MfaEmailToken {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  code_hash  String
  expires_at DateTime
  created_at DateTime @default(now())
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  email      String   @db.VarChar(255)
  token      String   @unique @db.VarChar(64)
  expires_at DateTime
  created_at DateTime @default(now())
}

model AuditLog {
  id            String   @id @default(uuid())
  org_id        String
  org           Organization @relation(fields: [org_id], references: [id])
  user_id       String?
  user          User?    @relation(fields: [user_id], references: [id])
  action        String   @db.VarChar(100)
  resource_type String?  @db.VarChar(100)
  resource_id   String?
  metadata      Json?
  ip_address    String?  @db.VarChar(45)
  created_at    DateTime @default(now())
}

// ─── Compliance Engine ────────────────────────────────────────────────────────

enum ConsentType {
  prior_express
  prior_express_written
  implied
}

enum DncSource {
  national_registry
  internal_optout
  manual
}

enum ComplianceCheckType {
  consent
  dnc
  calling_window
  recording_disclosure
  optout_detection
}

enum ComplianceCheckStatus {
  passed
  failed
  skipped
}

model ConsentRecord {
  id             String      @id @default(uuid())
  org_id         String
  org            Organization @relation(fields: [org_id], references: [id])
  lead_id        String      @db.VarChar(255)
  consent_type   ConsentType
  consent_source String      @db.VarChar(255)
  consent_text   String?     @db.Text
  consented_at   DateTime
  expires_at     DateTime?
  revoked_at     DateTime?
  revoked_reason String?     @db.VarChar(255)
  metadata       Json?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt
}

model DncRegistry {
  id           String        @id @default(uuid())
  phone_number String        @db.VarChar(20)
  source       DncSource
  reason       String?       @db.VarChar(255)
  added_at     DateTime
  lead_id      String?       @db.VarChar(255)
  org_id       String?
  org          Organization? @relation(fields: [org_id], references: [id])
  call_id      String?       @db.VarChar(255)
  created_at   DateTime      @default(now())

  @@index([phone_number, org_id])
}

model ComplianceCheck {
  id         String                @id @default(uuid())
  org_id     String
  org        Organization          @relation(fields: [org_id], references: [id])
  call_id    String?               @db.VarChar(255)
  lead_id    String                @db.VarChar(255)
  check_type ComplianceCheckType
  status     ComplianceCheckStatus
  details    Json
  checked_at DateTime
  created_at DateTime              @default(now())
}

model RecordingDisclosure {
  id           String       @id @default(uuid())
  org_id       String
  org          Organization @relation(fields: [org_id], references: [id])
  name         String       @db.VarChar(255)
  language     String       @db.VarChar(10)
  text         String       @db.Text
  audio_url    String       @db.VarChar(500)
  duration_ms  Int
  jurisdiction String       @db.VarChar(50)
  is_default   Boolean      @default(false)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
}
